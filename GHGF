-- Fly
local function runFly()
    local Players = game:GetService("Players")
    local UIS = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local LP = Players.LocalPlayer
    local Char = LP.Character or LP.CharacterAdded:Wait()
    local Humanoid = Char:WaitForChild("Humanoid")
    local HRP = Char:WaitForChild("HumanoidRootPart")
    local Camera = workspace.CurrentCamera
    local SPEED = 50; local Flying = false
    local Keys = {W=false,A=false,S=false,D=false,Space=false,LeftShift=false}
    local vel, align, att

    local function setupForces()
        att=Instance.new("Attachment",HRP)
        vel=Instance.new("LinearVelocity"); vel.Attachment0=att; vel.MaxForce=math.huge
        vel.RelativeTo=Enum.ActuatorRelativeTo.World; vel.Parent=HRP
        align=Instance.new("AlignOrientation"); align.Attachment0=att
        align.Mode=Enum.OrientationAlignmentMode.OneAttachment; align.MaxTorque=math.huge
        align.Responsiveness=200; align.Parent=HRP
    end
    local function cleanupForces()
        if vel then vel:Destroy(); vel=nil end
        if align then align:Destroy(); align=nil end
        if att then att:Destroy(); att=nil end
    end
    local function getMoveVector()
        local move=Vector3.zero
        if Keys.W then move+=Camera.CFrame.LookVector end
        if Keys.S then move-=Camera.CFrame.LookVector end
        if Keys.A then move-=Camera.CFrame.RightVector end
        if Keys.D then move+=Camera.CFrame.RightVector end
        if Keys.Space then move+=Vector3.new(0,1,0) end
        if Keys.LeftShift then move-=Vector3.new(0,1,0) end
        if move.Magnitude>0 then move=move.Unit end
        return move
    end
    local function startFly()
        if Flying or not HRP or not Humanoid then return end
        local v=tonumber(flySpeedBox.Text); SPEED=(v and v>0) and v or 50
        setupForces(); Humanoid.PlatformStand=true; Flying=true
        RunService:BindToRenderStep("7v2Fly",Enum.RenderPriority.Character.Value+1,function()
            if not Flying or not vel or not align then return end
            vel.VectorVelocity=getMoveVector()*SPEED
            local look=Camera.CFrame.LookVector
            align.CFrame=CFrame.lookAt(Vector3.zero,Vector3.new(look.X,0,look.Z))
        end)
    end
    local function stopFly()
        if not Flying then return end
        RunService:UnbindFromRenderStep("7v2Fly")
        cleanupForces(); Humanoid.PlatformStand=false; Flying=false
    end
    local function toggle()
        if Flying then stopFly(); flyStroke.Color=Color3.fromRGB(130,50,180); flyBtn.BackgroundColor3=Color3.fromRGB(55,18,80)
        else startFly(); flyStroke.Color=Color3.fromRGB(100,255,100); flyBtn.BackgroundColor3=Color3.fromRGB(30,80,30) end
    end
    flyBtn.MouseButton1Click:Connect(toggle)
    UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if _G.keybindsBlocked then return end
        local k=i.KeyCode
        if k==Enum.KeyCode.X then toggle()
        elseif Keys[k.Name]~=nil then Keys[k.Name]=true end
    end)
    UIS.InputEnded:Connect(function(i,gp)
        if gp then return end
        local k=i.KeyCode
        if Keys[k.Name]~=nil then Keys[k.Name]=false end
    end)
    LP.CharacterAdded:Connect(function(char)
        stopFly(); Char=char; Humanoid=char:WaitForChild("Humanoid"); HRP=char:WaitForChild("HumanoidRootPart")
        flyStroke.Color=Color3.fromRGB(130,50,180); flyBtn.BackgroundColor3=Color3.fromRGB(55,18,80)
    end)
end
task.spawn(runFly)

