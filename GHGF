local function runAutoTutorial()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local Workspace = game:GetService("Workspace")
    if game.PlaceId ~= 138940708178498 then return end
    local player = Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    local tool = player.Backpack:FindFirstChild("1 punches") or character:FindFirstChild("1 punches")
    if tool then player.Character.Humanoid:EquipTool(tool) end
    ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/StartCutscene"):FireServer()
    wait(1)
    humanoidRootPart.CFrame = CFrame.new(-4,9,29)
    local jEvent = ReplicatedStorage:WaitForChild("JALADADEPELOEVENT")
    for i=1,3 do jEvent:FireServer() wait(0.1) end
