        runningCash=not runningCash
        cameraEnabled=runningCash
        collectCashStroke.Color=runningCash and Color3.fromRGB(100,255,100) or Color3.fromRGB(130,50,180)
        collectCashBtn.BackgroundColor3=runningCash and Color3.fromRGB(30,80,30) or Color3.fromRGB(55,18,80)
        if runningCash then destroySeatsLoop(); task.spawn(collectCash)
        else cameraEnabled=false end
    end)
end
