-- Shared helper: get nearest player to mouse
local function getNearestToMouse(LP, mouse, camera)
    local closest, shortest = nil, 800
    local mP = Vector2.new(mouse.X, mouse.Y)
    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local sp, vis = camera:WorldToScreenPoint(p.Character.HumanoidRootPart.Position)
            if vis then
                local d = (Vector2.new(sp.X, sp.Y) - mP).Magnitude
                if d < shortest then shortest = d; closest = p end
            end
        end
    end
    return closest
end

-- Shared instant-hit logic factory
-- Each weapon gets its own independent state
local function makeInstantHitWeapon(btn, stroke, LP, mouse, camera)
    local enabled = false
    local lockedT = nil
    local highlight = nil
    local originalSize = nil

    local function resetH(p)
        if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and originalSize then
            p.Character.HumanoidRootPart.Size = originalSize
            p.Character.HumanoidRootPart.Transparency = 0
            originalSize = nil
        end
    end

    local function expandH(p)
        if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = p.Character.HumanoidRootPart
            originalSize = hrp.Size
            hrp.Size = Vector3.new(500, 500, 500)
            hrp.Transparency = 0.9
            hrp.CanCollide = false
        end
    end

    local function removeHigh()
        if highlight then highlight:Destroy(); highlight = nil end
    end

    local function applyHigh(p)
        removeHigh()
        if p and p.Character then
            highlight = Instance.new("Highlight", p.Character)
            highlight.FillColor = Color3.fromRGB(255, 50, 50)
            highlight.OutlineColor = Color3.fromRGB(255, 150, 50)
        end
    end

    -- Bullet tracking
    workspace:WaitForChild("Bullets").ChildAdded:Connect(function(b)
        if not enabled or not b:IsA("BasePart") then return end
