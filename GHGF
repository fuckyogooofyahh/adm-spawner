    local function enableNoclip(character)
        return RunService.Stepped:Connect(function()
            for _,p in ipairs(character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
        end)
    end
    RunService.RenderStepped:Connect(function()
        if cameraEnabled and HRP and Camera then
            Camera.CFrame=CFrame.new(HRP.Position+Vector3.new(0,10,0),HRP.Position+Vector3.new(0,-10,5))
        end
    end)
    local function teleportTween(targetPos, speed)
        moving=true; noclipConnection=enableNoclip(Char)
        local fPos=targetPos+Vector3.new(0,4,0)
        local dur=math.max((HRP.Position-fPos).Magnitude/speed,0.3)
        local tw=TweenService:Create(HRP,TweenInfo.new(dur,Enum.EasingStyle.Linear),{CFrame=CFrame.new(fPos)})
        tw:Play(); tw.Completed:Wait(); moving=false
        if noclipConnection then noclipConnection:Disconnect(); noclipConnection=nil end
    end
    local function modifyDamageables()
        local folder=Workspace:FindFirstChild("Damageables")
        if folder then for _,m in ipairs(folder:GetChildren()) do
            for _,p in ipairs(m:GetDescendants()) do
                if p:IsA("BasePart") then p.Transparency=1; p.Size=Vector3.new(1000,1000,1000); p.CanCollide=false end
            end
        end end
    end
    local function autoPunch(dur)
        local st=tick()
        while tick()-st<dur and runningATM do
            if RS:FindFirstChild("PUNCHEVENT") then RS.PUNCHEVENT:FireServer(1) end
            task.wait(0.01)
        end
    end
    local function destroySeatsLoop()
        task.spawn(function()
            while runningATM or runningCash do
                for _,p in ipairs(Workspace:GetDescendants()) do
                    if p:IsA("Seat") or p:IsA("VehicleSeat") then p:Destroy() end
                end
                task.wait(5)
            end
        end)
    end
    local function isUnderground(p) return (p.Position.Y-(p.Size.Y*0.5))<0 end
    local function isBugged(p)
        if not p:IsA("BasePart") then return true end
        if p.Anchored then return true end
        if p.Size.Magnitude<0.5 then return true end
        return false
    end
    local function getClosestCash()
        local folder=Workspace:FindFirstChild("Cash")
        if not folder then return nil end
        local closest,dist=nil,math.huge
        for _,c in ipairs(folder:GetChildren()) do
            if c:IsA("BasePart") and c.Name=="Cash" and not isUnderground(c) and not isBugged(c) then
                local d=(HRP.Position-c.Position).Magnitude
                if d<dist then closest=c; dist=d end
            end
        end
        return closest
    end
    local function spamPrompt(prompt)
        if not runningCash or not prompt then return end
        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
            local origLOS=prompt.RequiresLineOfSight
            prompt.RequiresLineOfSight=false; prompt.HoldDuration=0
            local st=os.clock()
            while runningCash and os.clock()-st<0.25 do
                prompt:InputHoldBegin(); task.wait(0.02); prompt:InputHoldEnd(); task.wait(0.02)
            end
            prompt.RequiresLineOfSight=origLOS
        end
    end
    local function collectCash()
        while runningCash do
            if not Char.Parent then
                task.wait(3); Char=LP.Character or LP.CharacterAdded:Wait(); HRP=Char:WaitForChild("HumanoidRootPart")
            end
            local cash=getClosestCash()
            if cash then
                local allP={}
                for _,p in ipairs(Workspace:GetDescendants()) do
                    if p:IsA("ProximityPrompt") and not cash:IsAncestorOf(p) then p.Enabled=false; table.insert(allP,p) end
                end
                teleportTween(cash.Position,65)
                while moving do task.wait() end
                for _,pr in ipairs(cash:GetDescendants()) do
                    if pr:IsA("ProximityPrompt") and pr.Enabled then spamPrompt(pr) end
                end
                for _,pr in ipairs(allP) do pr.Enabled=true end
            else
                teleportTween(Vector3.new(152,8,-486),50); task.wait(0.5)
            end
            task.wait(0.05)
        end
    end
    task.spawn(function()
        while true do
            if runningATM or runningCash then
                local net=RS:FindFirstChild("Modules") and RS.Modules:FindFirstChild("Net") and RS.Modules.Net:FindFirstChild("RE/ChangePVP")
                if net then net:FireServer() end
            end
            task.wait(0.01)
        end
    end)
    atmBtn.MouseButton1Click:Connect(function()
        runningATM=not runningATM
        cameraEnabled=runningATM
        atmStroke.Color=runningATM and Color3.fromRGB(100,255,100) or Color3.fromRGB(130,50,180)
        atmBtn.BackgroundColor3=runningATM and Color3.fromRGB(30,80,30) or Color3.fromRGB(55,18,80)
        if runningATM then
            collectCashStroke.Color=Color3.fromRGB(130,50,180); collectCashBtn.BackgroundColor3=Color3.fromRGB(55,18,80)
            task.spawn(function()
                modifyDamageables(); destroySeatsLoop()
                task.spawn(function() while runningATM do autoPunch(10); task.wait(0.5) end end)
                task.wait(2); runningCash=true
                collectCashStroke.Color=Color3.fromRGB(100,255,100); collectCashBtn.BackgroundColor3=Color3.fromRGB(30,80,30)
                task.spawn(collectCash)
            end)
        else cameraEnabled=false end
    end)
