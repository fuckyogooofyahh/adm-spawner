local function runRemoveBarriers()
    local Workspace = game:GetService("Workspace")
    local toggleEnabled = false; local lockZones = {}
    local function removeTI(part)
        if part and part:IsA("BasePart") then
            for _,ti in ipairs(part:GetDescendants()) do if ti:IsA("TouchTransmitter") then ti:Destroy() end end
        end
    end
    local function processHouses()
        local folder=Workspace:FindFirstChild("PresetHousesPlots")
        if folder then for _,house in ipairs(folder:GetChildren()) do
            local lz=house:FindFirstChild("LockZone")
            if lz then removeTI(lz); table.insert(lockZones,lz) end
        end end
    end
    local function processMansion()
        local mansion=Workspace:FindFirstChild("Mansion")
        if mansion then
            local det=mansion:FindFirstChild("MansionDetector")
            if det then removeTI(det); det.CanCollide=not toggleEnabled end
            local ext=mansion:FindFirstChild("MansionExtensionDetector")
            if ext then removeTI(ext); ext.CanCollide=not toggleEnabled end
        end
    end
    local function updateZones()
        for _,p in ipairs(lockZones) do
            if p and p:IsA("BasePart") then p.Transparency=toggleEnabled and 1 or 0.35; p.CanCollide=not toggleEnabled end
        end
    end
    removeBarriersBtn.MouseButton1Click:Connect(function()
        toggleEnabled=not toggleEnabled
        removeBarriersStroke.Color=toggleEnabled and Color3.fromRGB(100,255,100) or Color3.fromRGB(130,50,180)
        removeBarriersBtn.BackgroundColor3=toggleEnabled and Color3.fromRGB(30,80,30) or Color3.fromRGB(55,18,80)
        processHouses(); processMansion(); updateZones()
    end)
end
