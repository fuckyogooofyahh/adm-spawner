        elseif k==Enum.KeyCode.S then FK.S=false elseif k==Enum.KeyCode.D then FK.D=false
        elseif k==Enum.KeyCode.Space then FK.Space=false elseif k==Enum.KeyCode.LeftShift then FK.LeftShift=false end
    end)
end
