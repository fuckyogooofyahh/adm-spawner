local function runSnowballMacro()
    local Players = game:GetService("Players")
    local VIM = game:GetService("VirtualInputManager")
    local RunService = game:GetService("RunService")
    local UIS = game:GetService("UserInputService")
    local LP = Players.LocalPlayer

    local TOOL_ORDER = {
        "Golden Snowball Launcher",
        "Snowball Launcher",
        "Loveboard"
    }

    local debounce = false
    local TAP_FINGER = 9
    local macroActive = false

    local character, backpack, camera
    local function loadCharacter(char)
        character = char
        backpack = LP:WaitForChild("Backpack")
        camera = workspace.CurrentCamera
    end

    if LP.Character then loadCharacter(LP.Character)
    else loadCharacter(LP.CharacterAdded:Wait()) end
    LP.CharacterAdded:Connect(loadCharacter)

    local function tapCenter()
        if not camera then return end
        local vp = camera.ViewportSize
        VIM:SendTouchEvent(TAP_FINGER, Enum.UserInputState.Begin.Value, vp.X*0.5, vp.Y*0.5)
        task.wait(0.01)
        VIM:SendTouchEvent(TAP_FINGER, Enum.UserInputState.End.Value, vp.X*0.5, vp.Y*0.5)
    end

    local function runCombo()
        if debounce then return end
        debounce = true
        snowballStatusLabel.Text = "Status: Running..."
        snowballMacroBtn.BackgroundColor3 = Color3.fromRGB(30, 80, 30)
        snowballStroke.Color = Color3.fromRGB(100, 255, 100)

        for _, name in ipairs(TOOL_ORDER) do
            local tool = backpack:FindFirstChild(name) or (character and character:FindFirstChild(name))
            if not tool then
                for _, obj in ipairs(backpack:GetChildren()) do
                    if obj:IsA("Tool") and string.find(string.lower(obj.Name), string.lower(name)) then
                        tool = obj; break
                    end
                end
            end
            if tool and character then
                local hum = character:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum:EquipTool(tool)
                    RunService.RenderStepped:Wait()
                    tool:Activate()
                    tapCenter()
                end
            end
            task.wait(0.05)
        end

        debounce = false
        snowballStatusLabel.Text = "Status: Ready"
        snowballMacroBtn.BackgroundColor3 = Color3.fromRGB(90, 20, 130)
        snowballStroke.Color = Color3.fromRGB(180, 80, 255)
    end

    snowballMacroBtn.MouseButton1Click:Connect(runCombo)

    UIS.InputBegan:Connect(function(input, processed)
        if processed then return end
        if _G.keybindsBlocked then return end
        if input.KeyCode == Enum.KeyCode.C then
            runCombo()
        end
    end)
end
