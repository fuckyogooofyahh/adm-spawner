-- Safe parent helper
local function safeParent(gui)
    local ok = false
    if gethui then
        ok = pcall(function() gui.Parent = gethui() end)
    end
    if not ok then
        ok = pcall(function() gui.Parent = CoreGui end)
    end
    if not ok then
        gui.Parent = playerGui
    end
end

-- Format numbers
local function fmt(n)
    local s = tostring(math.floor(n))
    return s:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

local function parse(s)
    if not s or s == "" or type(s) ~= "string" then return nil end
    local cleaned = s:gsub(",", ""):gsub("%s+", ""):gsub("R$", ""):gsub("Robux", ""):gsub("robux", "")
    return tonumber(cleaned)
end

local function parseImageId(imageString)
    if not imageString or imageString == "" then return nil end
    if imageString:match("^rbxassetid://%d+$") then return imageString end
    local id = imageString:match("rbxassetid://(%d+)")
    if id then return "rbxassetid://" .. id end
    if tonumber(imageString) then return "rbxassetid://" .. tonumber(imageString) end
    id = imageString:match("[%?&]id=(%d+)")
    if id then return "rbxassetid://" .. id end
    id = imageString:match("assetId=(%d+)")
    if id then return "rbxassetid://" .. id end
    id = imageString:match("(%d+)")
    if id then return "rbxassetid://" .. id end
    return nil
end

local function getFirstWord(str)
    if not str or str == "" then return "" end
    return str:match("^(%S+)") or str
end

local function getTreadmillPriceByName(itemName)
    if not itemName or itemName == "" then return 17000 end
    local firstWord = getFirstWord(itemName)
    if firstWord == "" then return 17000 end
    local price = 17000
    pcall(function()
        local shopModal = playerGui:WaitForChild("SpeedGameUI"):WaitForChild("Modals"):WaitForChild("RobuxShopModal")
        local scrollingFrame = shopModal:WaitForChild("ScrollingFrame")
        local treadmills = scrollingFrame:WaitForChild("Treadmills")
        local mainFrame = treadmills:WaitForChild("MainFrame")
        local treadmillFrame = mainFrame:FindFirstChild(firstWord)
        if not treadmillFrame then
            treadmillFrame = mainFrame:FindFirstChild(firstWord .. "_Treadmill")
            if not treadmillFrame then
                treadmillFrame = mainFrame:FindFirstChild("Treadmill_" .. firstWord)
                if not treadmillFrame then
                    treadmillFrame = mainFrame:FindFirstChild(firstWord .. "Treadmill")
                    if not treadmillFrame then
                        treadmillFrame = mainFrame:FindFirstChild(firstWord .. "_Tredmill")
                        if not treadmillFrame then
                            treadmillFrame = mainFrame:FindFirstChild("Tredmill_" .. firstWord)
                        end
                    end
                end
            end
        end
        if not treadmillFrame then
            for _, child in ipairs(mainFrame:GetChildren()) do
                if child.Name:lower():find(firstWord:lower()) then
                    treadmillFrame = child
                    break
                end
            end
        end
        if treadmillFrame then
            pcall(function()
                local buyFrame = treadmillFrame:WaitForChild("Buy")
                local priceLabel = buyFrame:WaitForChild("Price")
                local parsed = parse(priceLabel.Text)
                if parsed then price = parsed end
            end)
        end
    end)
    return price
end

