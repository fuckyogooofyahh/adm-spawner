    if success and btn then
        if firesignal then
            pcall(function() firesignal(btn.MouseButton1Click, btn) end)
            pcall(function() firesignal(btn.Activated, btn) end)
            pcall(function() firesignal(btn.MouseButton1Down, btn) end)
            pcall(function() firesignal(btn.MouseButton1Up, btn) end)
        end
        
        if getconnections then
            for _, c in ipairs(getconnections(btn.MouseButton1Click)) do 
                pcall(function() c:Fire(btn) end) 
            end
            for _, c in ipairs(getconnections(btn.Activated)) do 
                pcall(function() c:Fire(btn) end) 
            end
            for _, c in ipairs(getconnections(btn.MouseButton1Down)) do 
                pcall(function() c:Fire(btn) end) 
            end
            for _, c in ipairs(getconnections(btn.MouseButton1Up)) do 
                pcall(function() c:Fire(btn) end) 
            end
        end
    end
    
    -- METHOD 2: Directly open RobuxShopModal (reconstructs game UI state)
    pcall(function()
        local speedUI = playerGui:WaitForChild("SpeedGameUI")
        local modals = speedUI:WaitForChild("Modals")
        local shopModal = modals:WaitForChild("RobuxShopModal")
        
        -- Ensure the entire modal chain is visible
        shopModal.Visible = true
        modals.Visible = true
        
        -- Reset modal appearance (common game patterns)
        if shopModal:IsA("GuiObject") then
            shopModal.BackgroundTransparency = 0
            shopModal.Position = UDim2.new(0.5, 0, 0.5, 0)
            shopModal.AnchorPoint = Vector2.new(0.5, 0.5)
            shopModal.ZIndex = 100
        end
        
        if shopModal:IsA("ImageLabel") or shopModal:IsA("ImageButton") then
            shopModal.ImageTransparency = 0
        end
        
        -- Enable background dimmer / blur / overlay (the game uses these)
        for _, child in ipairs(modals:GetChildren()) do
            local name = child.Name:lower()
            if name:find("bg") or name:find("dim") or name:find("blur") or name:find("overlay") or name:find("shadow") then
                child.Visible = true
                if child:IsA("GuiObject") then
                    child.BackgroundTransparency = 0.5
                    if child:IsA("ImageLabel") or child:IsA("ImageButton") then
                        child.ImageTransparency = 0.5
                    end
                end
            end
        end
        
        -- Also check SpeedGameUI direct children for full-screen overlays
        for _, child in ipairs(speedUI:GetChildren()) do
            local name = child.Name:lower()
            if (name:find("bg") or name:find("dim") or name:find("blur") or name:find("darken")) and child:IsA("GuiObject") then
                child.Visible = true
                if child:IsA("Frame") or child:IsA("ImageLabel") then
                    child.BackgroundTransparency = 0.5
                end
            end
        end
    end)
end)

-- Booth hooks
local processedBooths = {}

local function getId(obj)
    for name, val in pairs(obj:GetAttributes()) do
        if (name:lower():find("id") or name:lower():find("asset")) and type(val) == "number" then return val end
    end
    for _, c in ipairs(obj:GetChildren()) do
        if (c.Name:lower():find("id") or c.Name:lower():find("asset")) and (c:IsA("NumberValue") or c:IsA("IntValue")) then return c.Value end
    end
    if tonumber(obj.Name) then return tonumber(obj.Name) end
    local id = obj.Name:match("Item(%d+)")
    if id then return tonumber(id) end
    if obj.Parent then
        local pid = obj.Parent.Name:match("Item(%d+)")
        if pid then return tonumber(pid) end
    end
    return nil
end

local function getProductInfo(id)
    local ok, info = pcall(function() return game:GetService("MarketplaceService"):GetProductInfo(id, Enum.InfoType.GamePass) end)
    if ok and info then
        return {Name = info.Name or "Unknown", IconImageAssetId = id, PriceInRobux = info.PriceInRobux or 0, AssetId = id}
    end
    return {Name = "Unknown", IconImageAssetId = id, PriceInRobux = 0, AssetId = id}
end

local function getBoothUser(frame)
    local ok, result = pcall(function()
        for _, c in ipairs(frame:GetDescendants()) do
            if c:IsA("TextLabel") or c:IsA("TextButton") then
                local text = c.Text
                if text and text:find("@") then
                    local match = text:match("@([%w_]+)")
                    if match then return match end
                end
            end
        end
        return nil
    end)
    return ok and result or nil
end

local function hookBoothBtn(btn)
    if not (btn:IsA("TextButton") or btn:IsA("ImageButton")) then return end
    if processedBooths[btn] then return end
    if btn:FindFirstChild("CustomPurchaseOverlay") then return end
    local id = getId(btn)
    if not id then return end

    processedBooths[btn] = true

    local overlay = Instance.new("TextButton")
    overlay.Name = "CustomPurchaseOverlay"
    overlay.BackgroundTransparency = 1
    overlay.Text = ""
    overlay.Size = UDim2.new(1, 0, 1, 0)
    overlay.ZIndex = (btn.ZIndex or 1) + 10
    overlay.Parent = btn

    overlay.MouseButton1Click:Connect(function()
        local cid = getId(btn) or id
        local info = getProductInfo(cid)
        local boothUser = getBoothUser(btn) or username
        local giftMessage = "Bought from " .. boothUser .. "!"
        createPurchaseModal(boothUser, giftMessage, tostring(info.IconImageAssetId), info.Name)
    end)
end

